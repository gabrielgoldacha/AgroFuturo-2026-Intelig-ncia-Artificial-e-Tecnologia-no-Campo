document.addEventListener('DOMContentLoaded', () => {
    
    // ==========================================================================
    // SISTEMA ACCORDION (EXPANSÃO DE CONTEÚDO)
    // ==========================================================================
    const accordionHeaders = document.querySelectorAll('.accordion-header');

    accordionHeaders.forEach(header => {
        header.addEventListener('click', function() {
            const item = this.parentElement;
            const content = this.nextElementSibling;
            const isOpen = item.classList.contains('active');

            // Fecha todos antes de abrir o atual (comportamento solo opcional)
            document.querySelectorAll('.accordion-item').forEach(i => {
                i.classList.remove('active');
                i.querySelector('.accordion-content').style.maxHeight = null;
                i.querySelector('.accordion-header').setAttribute('aria-expanded', 'false');
            });

            if (!isOpen) {
                item.classList.add('active');
                content.style.maxHeight = content.scrollHeight + "px";
                this.setAttribute('aria-expanded', 'true');
            }
        });
    });

    // ==========================================================================
    // BARRA DE ACESSIBILIDADE FLUTUANTE
    // ==========================================================================
    let currentFontSize = 100; // Percentual base
    const body = document.body;

    const btnIncreaseFont = document.getElementById('btn-increase-font');
    const btnDecreaseFont = document.getElementById('btn-decrease-font');
    const btnToggleTheme = document.getElementById('btn-toggle-theme');
    const btnSpeechStart = document.getElementById('btn-speech-start');
    const btnSpeechStop = document.getElementById('btn-speech-stop');

    // Controle de Tamanho de Fonte Geral
    btnIncreaseFont.addEventListener('click', () => {
        if (currentFontSize < 130) {
            currentFontSize += 5;
            document.documentElement.style.fontSize = `${currentFontSize}%`;
        }
    });

    btnDecreaseFont.addEventListener('click', () => {
        if (currentFontSize > 85) {
            currentFontSize -= 5;
            document.documentElement.style.fontSize = `${currentFontSize}%`;
        }
    });

    // Modo Claro / Escuro
    btnToggleTheme.addEventListener('click', () => {
        body.classList.toggle('dark-mode');
        const isDark = body.classList.contains('dark-mode');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });

    // Recupera tema salvo anteriormente pelo leitor
    if (localStorage.getItem('theme') === 'dark') {
        body.classList.add('dark-mode');
    }

    // ==========================================================================
    // ACESSIBILIDADE: LEITURA POR VOZ (SpeechSynthesis API)
    // ==========================================================================
    let speechUtterance = null;
    const synth = window.speechSynthesis;

    btnSpeechStart.addEventListener('click', () => {
        // Evita multiplas leituras simultâneas
        if (synth.speaking) {
            synth.cancel();
        }

        // Seleciona de forma inteligente apenas os textos estruturais e informativos principais
        const mainContent = document.getElementById('conteudo-principal');
        if (!mainContent) return;

        // Limpa tags e pega puramente o texto limpo para evitar ler botões ou códigos do Accordion
        let textToRead = '';
        const structuralElements = mainContent.querySelectorAll('p, h2, .quote-box');
        
        structuralElements.forEach(el => {
            textToRead += el.textContent + ' . ';
        });

        speechUtterance = new SpeechSynthesisUtterance(textToRead);
        speechUtterance.lang = 'pt-BR';
        speechUtterance.rate = 1.0; // Velocidade natural

        // Feedback visual simples ao começar
        btnSpeechStart.style.backgroundColor = 'var(--color-accent-green)';

        speechUtterance.onend = () => {
            btnSpeechStart.style.backgroundColor = '';
        };

        synth.speak(speechUtterance);
    });

    btnSpeechStop.addEventListener('click', () => {
        if (synth.speaking) {
            synth.cancel();
            btnSpeechStart.style.backgroundColor = '';
        }
    });

    // ==========================================================================
    // ENVIOS DOS FORMULÁRIOS COM INTERAÇÕES FLUIDAS
    // ==========================================================================
    
    // Inscrição Seminário
    const formInscricao = document.getElementById('form-inscricao');
    const feedbackInscricao = document.getElementById('feedback-inscricao');

    formInscricao.addEventListener('submit', (e) => {
        e.preventDefault();
        
        // Simulação assíncrona premium de envio
        feedbackInscricao.style.display = 'block';
        feedbackInscricao.textContent = `Obrigado, ${document.getElementById('nome').value}! Sua inscrição para o seminário foi garantida.`;
        
        formInscricao.reset();
        
        setTimeout(() => {
            feedbackInscricao.style.display = 'none';
        }, 5000);
    });

    // Comentários do Leitor
    const formComentario = document.getElementById('form-comentario');
    const feedbackComentario = document.getElementById('feedback-comentario');

    formComentario.addEventListener('submit', (e) => {
        e.preventDefault();
        
        feedbackComentario.style.display = 'block';
        formComentario.reset();

        setTimeout(() => {
            feedbackComentario.style.display = 'none';
        }, 4000);
    });
});